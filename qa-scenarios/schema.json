{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Golden customer scenario",
  "type": "object",
  "required": ["id", "app", "persona", "risk", "state", "trigger", "expected", "automation", "evidence"],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "app": { "type": "string" },
    "persona": { "type": "string" },
    "risk": { "type": "string", "enum": ["trust", "conversion", "clarity", "retention", "revenue", "shipping"] },
    "state": { "type": "string" },
    "trigger": { "type": "string" },
    "expected": { "type": "array", "minItems": 2, "items": { "type": "string" } },
    "automation": { "type": "string", "enum": ["static", "unit", "integration", "simulator", "manual"] },
    "evidence": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "failureMeans": { "type": "string" }
  }
}
