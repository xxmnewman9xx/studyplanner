{
  "cli": {
    "version": ">= 18.8.1",
    "appVersionSource": "local"
  },
  "build": {
    "app-dev": {
      "environment": "preview",
      "distribution": "internal",
      "ios": {
        "simulator": false
      }
    },
    "app-dev-simulator": {
      "environment": "development",
      "distribution": "internal",
      "ios": {
        "simulator": true
      }
    },
    "production": {
      "environment": "production",
      "distribution": "store",
      "autoIncrement": false
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "6766181202"
      }
    }
  }
}
