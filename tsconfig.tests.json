{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": ".test-build",
    "rootDir": ".",
    "noEmit": false,
    "module": "Node16",
    "moduleResolution": "Node16",
    "target": "ES2022",
    "types": ["node"],
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts", "tests/**/*.ts"],
  "exclude": ["node_modules", ".test-build", ".expo", "dist", "dist-smoke", "dist-smoke-*"]
}
