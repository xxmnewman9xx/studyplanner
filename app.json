{
  "expo": {
    "name": "Study Planner: Syllabus AI",
    "slug": "study-planner-syllabus-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/app/study-planner-icon.png",
    "scheme": "studyplanner",
    "splash": {
      "backgroundColor": "#F5F7FB"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mattnewman.studyplanner",
      "icon": "./assets/app/study-planner-icon.png",
      "buildNumber": "10",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "Scan syllabus pages so Study Planner can help create your course plan.",
        "NSPhotoLibraryUsageDescription": "Choose syllabus screenshots or photos to import into your plan.",
        "NSCalendarsFullAccessUsageDescription": "Sync assignment and exam dates to your calendar.",
        "NSUserNotificationsUsageDescription": "Send calm reminders before deadlines, exams, and classes."
      }
    },
    "android": {
      "package": "com.studyplanner.syllabusai",
      "permissions": [
        "CAMERA",
        "READ_CALENDAR",
        "WRITE_CALENDAR",
        "POST_NOTIFICATIONS"
      ]
    },
    "plugins": [
      "expo-calendar",
      "expo-document-picker",
      "expo-image-picker",
      "expo-notifications",
      "expo-iap"
    ],
    "extra": {
      "eas": {
        "projectId": "69335c75-753e-424e-8a76-c8bd2455a112"
      }
    },
    "owner": "xxmnewman9xx"
  }
}
