{
  "expo": {
    "name": "StudyPlanner: Syllabus AI",
    "slug": "study-planner-syllabus-ai",
    "version": "1.0.2",
    "orientation": "default",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/app/study-planner-icon.png",
    "scheme": "studyplanner",
    "splash": {
      "image": "./assets/app/study-planner-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F8F6FF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mattnewman.studyplanner",
      "icon": "./assets/app/study-planner-icon.png",
      "buildNumber": "18",
      "entitlements": {
        "com.apple.security.application-groups": [
          "group.com.mattnewman.studyplanner"
        ]
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "Scan syllabus pages so StudyPlanner can help create your course plan.",
        "NSPhotoLibraryUsageDescription": "Choose syllabus screenshots or photos to import into your plan.",
        "NSCalendarsFullAccessUsageDescription": "Sync assignment and exam dates to your calendar.",
        "NSUserNotificationsUsageDescription": "Send calm reminders before deadlines, exams, and classes."
      }
    },
    "android": {
      "package": "com.studyplanner.syllabusai",
      "adaptiveIcon": {
        "foregroundImage": "./assets/app/study-planner-icon.png",
        "backgroundColor": "#F8F6FF"
      },
      "permissions": [
        "CAMERA",
        "READ_CALENDAR",
        "WRITE_CALENDAR",
        "POST_NOTIFICATIONS"
      ]
    },
    "plugins": [
      "expo-calendar",
      "expo-document-picker",
      "expo-image-picker",
      "expo-notifications",
      "expo-iap",
      "expo-font",
      [
        "expo-widgets",
        {
          "bundleIdentifier": "com.mattnewman.studyplanner.widgets",
          "groupIdentifier": "group.com.mattnewman.studyplanner",
          "widgets": [
            {
              "name": "StudyPlannerTodayWidget",
              "displayName": "StudyPlanner Today",
              "description": "Shows reviewed homework due today from your StudyPlanner plan.",
              "contentMarginsDisabled": true,
              "supportedFamilies": [
                "systemSmall",
                "systemMedium"
              ]
            },
            {
              "name": "StudyPlannerUpcomingWidget",
              "displayName": "StudyPlanner Upcoming",
              "description": "Shows the next reviewed deadlines from your StudyPlanner plan.",
              "contentMarginsDisabled": true,
              "supportedFamilies": [
                "systemSmall",
                "systemMedium"
              ]
            }
          ]
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "69335c75-753e-424e-8a76-c8bd2455a112",
        "build": {
          "experimental": {
            "ios": {
              "appExtensions": [
                {
                  "targetName": "ExpoWidgetsTarget",
                  "bundleIdentifier": "com.mattnewman.studyplanner.widgets",
                  "entitlements": {
                    "com.apple.security.application-groups": [
                      "group.com.mattnewman.studyplanner"
                    ]
                  }
                }
              ]
            }
          }
        }
      }
    },
    "owner": "xxmnewman9xx"
  }
}
